# --- Dependencies ---
# This ignores node_modules in the root, frontend, and backend folders
node_modules/
jspm_packages/


# --- Production Builds ---
# Ignores the folders where your code is compiled for the web
dist/
build/
out/

# --- Environment Variables (CRITICAL) ---
# Never upload your secrets, API keys, or database passwords
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Logs ---
# Error logs created by npm or the server
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Testing ---
# If you eventually add Vitest or Jest
coverage/
*.lcov

# --- Editors & OS ---
# Files created by VS Code, Mac, or Windows
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Database & Uploads ---
# Local SQLite databases or user-uploaded images
*.sqlite
backend/uploads/